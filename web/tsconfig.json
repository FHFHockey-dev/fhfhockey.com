{
  "compilerOptions": {
    "target": "es2015",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "components/*": ["./components/*"],
      "contexts/*": ["./contexts/*"],
      "hooks/*": ["./hooks/*"],
      "lib/*": ["./lib/*"],
      "next-seo.config": ["./next-seo.config.js"],
      "pages/*": ["./pages/*"],
      "public/*": ["./public/*"],
      "styles/*": ["./styles/*"],
      "utils/*": ["./utils/*"]
    },
    "resolvePackageJsonExports": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": false
  },
  "include": [
    "next-env.d.ts",
    "yahoo-fantasy.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "vitest.config.mts",
    "components/TeamLandingPage/teamLandingPage.js"
  ],
  "exclude": ["node_modules"]
}
